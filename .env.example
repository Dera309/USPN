# USPN Configuration - .env.example

# ── Server Config ─────────────────────────────────────────────────────────────
PORT=5000
# MONGO_URI: Full connection string (e.g., mongodb+srv://...)
MONGO_URI=mongodb://localhost:27017/uspn
# JWT_SECRET: Strong random string for signing login tokens
JWT_SECRET=your_strong_random_secret_here

# ── Frontend Config ───────────────────────────────────────────────────────────
# FRONTEND_URL: The public URL of your deployed platform (for CORS)
FRONTEND_URL=https://your-uspn-site.render.com

# ── Google Maps Config ────────────────────────────────────────────────────────
# VITE_MAPS_KEY: Your Google Maps Static API Key (must start with VITE_ to be picked up by Vite)
VITE_MAPS_KEY=YOUR_GOOGLE_MAPS_STATIC_API_KEY
